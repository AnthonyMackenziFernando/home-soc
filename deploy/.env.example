# Copy this file to `.env` (same folder) and adjust as needed:
#     cp .env.example .env
#
# docker compose reads `.env` automatically. The real `.env` is git-ignored so
# your local tuning never lands in the repo.

# ---------------------------------------------------------------------------
# Wazuh stack version. Keep the three images (manager/indexer/dashboard) on the
# same tag. Valid tags: https://github.com/wazuh/wazuh-docker/tags
# ---------------------------------------------------------------------------
WAZUH_VERSION=4.14.6

# ---------------------------------------------------------------------------
# OpenSearch (indexer) JVM heap. This is the single biggest RAM lever.
#   512m  -> fits an 8 GB laptop with room for one victim VM (default)
#   1g    -> smoother if you have 16 GB
#   2g    -> only on 32 GB+ hosts
# Rule of thumb: heap should be <= 50% of the RAM you can spare for the indexer.
# ---------------------------------------------------------------------------
INDEXER_HEAP=512m

# ---------------------------------------------------------------------------
# NOTE ON CREDENTIALS
# The default Wazuh demo passwords (admin / SecretPassword, etc.) are baked into
# config/wazuh_indexer/internal_users.yml and the compose environment. They are
# fine for an isolated lab but MUST be rotated before exposing anything.
# See docs/10-hardening.md for the exact rotation procedure.
# ---------------------------------------------------------------------------
